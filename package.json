{
  "name": "george",
  "version": "0.1.0",
  "private": true,
  "description": "George v2 — single-dispatcher Claude Agent SDK service backing a Telegram bot, with Convex state, ICU coaching, and Actual Budget finance tools.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:convex",
    "dev:server": "tsx watch server/index.ts",
    "dev:convex": "convex dev",
    "start": "tsx server/index.ts",
    "deploy:convex": "convex deploy",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx scripts/migrate/index.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "convex": "^1.36.1",
    "cors": "^2.8.5",
    "croner": "^9.0.0",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
