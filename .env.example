# ---- Convex ----
# Cloud (default): get these by running `npx convex dev`. Convex will create
# a project and auto-populate your .env.local.
CONVEX_DEPLOYMENT=
CONVEX_URL=
VITE_CONVEX_URL=

# ---- Convex (self-hosted, optional) ----
# Run `npm run convex:selfhost up` to start a local backend + dashboard, then
# `npm run convex:selfhost key` to mint these. When set, point the rest of
# the app at the local URLs (replace VITE_CONVEX_URL above) and use
# `npm run convex:selfhost dev` / `... deploy` instead of the cloud commands.
CONVEX_SELF_HOSTED_URL=
CONVEX_SELF_HOSTED_ADMIN_KEY=
VITE_CONVEX_SITE_URL=

# ---- Sendblue (iMessage bridge) ----
# Sign up at https://sendblue.com, get your API keys + provisioned number.
# Webhook URL you'll set in Sendblue dashboard:  <PUBLIC_URL>/sendblue/webhook
#
# SENDBLUE_FROM_NUMBER MUST be your Sendblue-provisioned number (the one
# people text TO), not your personal cell. Sendblue's API requires it.
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=

# --- Telegram (optional) ------------------------------------------------
# Bot token from @BotFather. Without it, Telegram channel is disabled.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat_ids that may DM the bot. Combines with the Convex
# allowlist (npm run telegram:approve to manage at runtime).
TELEGRAM_ALLOWED_CHAT_IDS=
# STRONGLY RECOMMENDED. Random secret (32 bytes hex). The only auth gate
# against spoofed POSTs to /telegram/webhook. Auto-generated by
# `npm run setup`. Without it, any caller who knows your webhook URL can
# inject inbound messages.
TELEGRAM_WEBHOOK_SECRET=
# Set to "false" to opt out of webhook auto-registration on `npm run dev`.
TELEGRAM_AUTO_WEBHOOK=
# Optional: bot username for friendlier "text @<bot>" error messages.
TELEGRAM_BOT_USERNAME=
# Optional: max voice-note duration in seconds. Above this, transcription
# is skipped and the user is prompted to type. Default 600 (10 min).
TELEGRAM_VOICE_MAX_DURATION=
# Optional — file_ids for npm run telegram:smoke. Upload a photo + PDF to
# your bot once via the Telegram client, capture the file_id from the inbound
# webhook payload (or run scripts/telegram-grab-fileid.mjs if it exists),
# and paste the file_ids here to enable the photo + document smoke steps.
TELEGRAM_SMOKE_PHOTO_FILE_ID=
TELEGRAM_SMOKE_PDF_FILE_ID=

# ---- Claude model ----
# Uses your Claude Code subscription automatically — no separate API key needed.
# Override with ANTHROPIC_API_KEY if you want to bypass the subscription.
# This is the *fallback*; runtime overrides set via the iMessage set_model tool
# (stored in the Convex `settings` table) take precedence.
BOOP_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# ---- Proactive email surfacing ----
# Set to "false" to skip auto-registering the Composio webhook URL on each
# `npm run dev`. Use when you want to manage the subscription manually.
# COMPOSIO_AUTO_WEBHOOK=

# ---- Upgrade notifications ----
# On `npm run dev`, Boop checks your `upstream` remote for new commits and
# prints a banner with the commit count + a reminder to run `/upgrade-boop`.
# Set to `false` to silence the check entirely.
# BOOP_UPSTREAM_CHECK=true

# ---- Embeddings (optional — paid providers for memory recall) ----
# Tried in order: Voyage → OpenAI → local Transformers.js (Xenova/bge-large-
# en-v1.5, 1024-dim, free, ~440MB one-time download). Leave both blank to
# use the local fallback. All three produce 1024-dim vectors so the Convex
# index stays compatible regardless of which is active.
# VOYAGE_API_KEY=
# OPENAI_API_KEY=

# ---- Inbound attachments (vision + extraction; requires OPENAI_API_KEY) ----
# Optional — model used for inbound photo / PDF-page vision-to-text.
# Defaults to gpt-4o. Set to gpt-4o-mini for cheaper but lower-fidelity
# descriptions. The model name is recorded on each usageRecords row.
BOOP_VISION_MODEL=

# Optional — hard ceiling on vision spend per inbound message (in USD).
# Defaults to 1.50. Adjust up or down to match your expected file mix
# (raise for image-heavy 20+-page PDFs; lower for tight cost control).
BOOP_VISION_COST_CAP_USD=

# ---- Server ----
PORT=3456

# Public URL for your server.
# - Leave as http://localhost:3456 if you're using free ngrok (URL changes each restart).
# - Set to your stable public URL (e.g. https://boop.mydomain.com) if you use
#   Cloudflare Tunnel, a Caddy server, or any other tunnel with a fixed URL —
#   `npm run dev` will then skip ngrok.
PUBLIC_URL=http://localhost:3456

# Optional: ngrok RESERVED domain (paid plan). Example: "boop.ngrok.app".
# When set, `npm run dev` launches ngrok with --domain=$NGROK_DOMAIN so your
# public URL stays the same across restarts.
# NGROK_DOMAIN=

# When free-plan ngrok is in use, `npm run dev` auto-registers the new tunnel
# URL with Sendblue as the inbound (receive) webhook so you don't have to
# paste it into the dashboard. Set to "false" to disable this behavior.
# SENDBLUE_AUTO_WEBHOOK=true

# ---- Composio (1000+ integrations, zero-code) ----
# Get an API key at https://app.composio.dev/developers.
# Once set, connect toolkits (Gmail, Slack, GitHub, Linear, …) from the
# Debug UI's Connections tab. Each connected toolkit becomes available to
# the agent via spawn_agent(integrations: [...]).
COMPOSIO_API_KEY=

# Optional: stable user id Composio keys connections under. Defaults to
# "boop-default". Override only if you already manage Composio sessions
# elsewhere and want Boop to reuse that user.
# COMPOSIO_USER_ID=

# ---- Granola (native integration; bypasses Composio) ----
# Granola's Composio toolkit is MCP-only and doesn't work with the standard
# OAuth Connect flow. Use a native API key instead: in the Granola desktop
# app go to Settings → Connectors → API keys. Token format: grn_...
# When set, the agent gets `granola` as a spawnable integration.
GRANOLA_API_TOKEN=

# ---- Apify (native integration; web-scraping actors) ----
# Get a token at https://console.apify.com → Settings → Integrations → API tokens.
# Token format: apify_api_...
# When set, the agent gets `apify` as a spawnable integration with three tools:
# search_actors / get_actor / run_actor — for finding and running scrapers
# (Airbnb, Booking.com, Zillow, LinkedIn, Amazon, …) on demand.
APIFY_API_TOKEN=

# Cost guards for run_actor. Each is a hard ceiling — the agent can pass a
# lower per-run value but never exceed these. Tune to match your risk tolerance.
# APIFY_RUN_BUDGET_CAP_USD=1.0          # max estimated $ for per-item-priced runs
# APIFY_RUN_TIMEOUT_CAP_SECONDS=300     # max wall-clock seconds per run
# APIFY_RUN_MEMORY_CAP_MB=4096          # max memory per run (more = faster + pricier)
# APIFY_RUN_MAX_ITEMS_CAP=200           # max dataset items per run

# ---- Gemini image generation (native integration) ----
# Get a key at https://aistudio.google.com/apikey.
# When set, the agent gets `gemini` as a spawnable integration with two tools:
# generate_image (text → image) and edit_image (image + instruction → image),
# both backed by Gemini 2.5 Flash Image ("Nano Banana"). Output is uploaded to
# Convex storage and the signed URL is returned for the agent to paste.
GEMINI_API_KEY=

# Optional override (default: gemini-2.5-flash-image). Useful for trying
# preview / Imagen variants without code changes.
# GEMINI_IMAGE_MODEL=

# ---- Web fetch (always-on; tiered URL → markdown) ----
# The `web` integration's fetch_url tool tries plain HTTP + Readability first
# (free, fast). When the page is JS-rendered or returns a bot wall, it falls
# back to a headless renderer. Configure ONE of the two below — crawl4ai wins
# if both are set. Without either, the tool still works but only on
# server-rendered pages.
#
# Firecrawl (hosted SaaS): https://firecrawl.dev — paste your key.
# FIRECRAWL_API_KEY=
#
# crawl4ai (self-hosted Docker): base URL of your crawl4ai server, e.g.
# http://localhost:11235. Expects POST /md → { url } returning markdown.
# CRAWL4AI_BASE_URL=

# ---- Browser automation (Steel.dev + Stagehand) ----
# When STEEL_API_KEY is set, the agent gets a `browser` integration with
# tools to open sessions, navigate, click/type via natural language
# (Stagehand), extract structured data, and screenshot. ANTHROPIC_API_KEY
# is also required — Stagehand calls Anthropic directly for its act/
# extract/observe LLM steps (separate from the parent agent's calls).
#
# Get a Steel key at https://app.steel.dev/settings/api-keys.
STEEL_API_KEY=

# Optional. Hard wall-clock cap on a single session before it's auto-
# closed (default 20). Mostly a guardrail against forgotten sessions
# racking up Steel charges.
# BROWSER_SESSION_TIMEOUT_MINUTES=20

# Optional. Model Stagehand uses for natural-language page reasoning.
# Defaults to claude-sonnet-4-6 (a good balance of cost vs accuracy on
# DOM-grounded tasks).
# BROWSER_DEFAULT_MODEL=claude-sonnet-4-6

# ---- Browser-action credential vault ----
# 32-byte AES-256-GCM key used to encrypt stored passwords + TOTP secrets
# for the (upcoming) browser-action integration. Convex only ever stores
# ciphertext; this key is the actual security boundary.
#
# Generate one with:   openssl rand -base64 32
#
# Lose this key and every saved credential becomes unrecoverable. Back it
# up wherever you keep your other server secrets (1Password, etc.).
BROWSER_CREDENTIAL_KEY=

# ---- APNs (iOS push notifications, optional) ---------------------------
# Lets the boop server send a push to the iPhone app when an assistant
# reply or proactive notice lands while the app is backgrounded. Without
# these vars the server boots fine and logs `[apns] disabled (config
# missing)`; SSE still delivers in foreground.
#
# Setup:
#   1. https://developer.apple.com/account/resources/authkeys/list →
#      "Create a Key", check "Apple Push Notifications service (APNs)",
#      download the .p8 file. Note the Key ID + your Team ID.
#   2. Paste the full .p8 contents into APNS_PRIVATE_KEY below (newlines
#      may be escaped as \n on a single line — both forms work).
#   3. APNS_BUNDLE_ID defaults to dev.boop.Boop (the value in
#      ios/project.yml). Override if you changed the bundle ID for your
#      fork.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=dev.boop.Boop
APNS_PRIVATE_KEY=
