# ---- Convex ----
# Run `npx convex dev` once to provision the deployment. It will populate
# .env.local with the active deployment values; copy them here when you
# want to share defaults with another machine.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
# Optional server-only override. Falls back to VITE_CONVEX_URL.
# CONVEX_URL=

# ---- Telegram ----
# Create the bot with @BotFather. The webhook secret is whatever you pass
# to setWebhook(secret_token=...); George verifies it on every inbound
# update. Allowed chat id locks the bot to a single conversation.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_ID=

# Public HTTPS URL the bot webhook posts to. Use a stable tunnel
# (Cloudflare Tunnel, Caddy, ngrok reserved domain) or your VPS hostname.
PUBLIC_BASE_URL=http://localhost:3456

# ---- Intervals.icu ----
# Found at https://intervals.icu/settings — "API Keys".
ICU_ATHLETE_ID=
ICU_API_KEY=

# ---- Actual Budget ----
# Self-hosted Actual server (https://actualbudget.org).
ACTUAL_SERVER_URL=
ACTUAL_PASSWORD=
ACTUAL_BUDGET_SYNC_ID=
ACTUAL_BUDGET_PASSWORD=

# ---- Runtime safety ----
# DRY_RUN=on short-circuits every outbound write (ICU PUT, Actual writes,
# Telegram send) to a logged no-op. Flip to "off" only after cutover.
DRY_RUN=on

# IANA timezone the dispatcher reasons in (cron expressions, day rollovers,
# log timestamps). Override per-deployment.
USER_TIMEZONE=Europe/Amsterdam

# ---- Server ----
PORT=3456
